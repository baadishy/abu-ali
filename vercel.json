{
  "version": 2,
  "installCommand": "npm ci --include=optional",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "dist-server/**"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
